<div class="min-h-screen bg-forest flex flex-col items-center justify-center px-4 py-12">

  <div class="mb-10 text-center">
    <span class="font-fraunces text-4xl font-light italic text-cream tracking-tight">Citable</span>
  </div>

  <div class="w-full max-w-sm">
    <div class="rounded-3xl bg-cream px-8 py-8 shadow-2xl">
      <h1 class="font-fraunces text-xl font-light text-forest mb-1">¿Olvidaste tu contraseña?</h1>
      <p class="text-xs text-forest/50 mb-6">Te enviaremos un enlace para restablecerla</p>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>

        <div>
          <%= f.label :email, "Tu correo electrónico", class: "block text-xs font-semibold uppercase tracking-wider text-forest/50 mb-1.5" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "block w-full rounded-xl border border-cream-dark bg-white px-3.5 py-2.5 text-sm text-forest placeholder:text-forest/30 focus:border-brand focus:ring-2 focus:ring-brand/10 focus:outline-none",
              placeholder: "ana@example.com" %>
        </div>

        <div class="pt-2">
          <%= f.submit "Enviar instrucciones", class: "w-full rounded-xl bg-brand py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-light transition-colors cursor-pointer" %>
        </div>
      <% end %>

      <div class="mt-5 text-center">
        <%= link_to "Volver al inicio de sesión", new_session_path(resource_name),
            class: "text-xs text-forest/50 hover:text-forest transition-colors" %>
      </div>
    </div>
  </div>
</div>
