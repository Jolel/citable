<% content_for :title, "Citas — #{current_account.name}" %>

<%# ── Page header ──────────────────────────────── %>
<div class="flex items-start justify-between gap-4 mb-6">
  <div>
    <h1 class="font-fraunces text-2xl font-light text-forest">Citas</h1>
    <p class="text-sm text-forest/50 mt-0.5">Gestiona todas las citas de tu negocio</p>
  </div>
  <div class="flex items-center gap-2 shrink-0">
    <%= link_to dashboard_calendar_path,
        class: "inline-flex items-center gap-2 rounded-xl border border-cream-dark bg-white px-4 py-2.5 text-sm font-semibold text-forest shadow-sm transition-colors hover:border-brand/20 hover:text-brand" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75V4.5m7.5 2.25V4.5M3.75 9.75h16.5M4.5 6.75h15A1.5 1.5 0 0 1 21 8.25v10.5a1.5 1.5 0 0 1-1.5 1.5h-15A1.5 1.5 0 0 1 3 18.75V8.25a1.5 1.5 0 0 1 1.5-1.5Z" />
      </svg>
      Calendario
    <% end %>

    <%= link_to new_dashboard_booking_path,
        class: "inline-flex items-center gap-2 rounded-xl bg-brand px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-light transition-colors" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      Nueva cita
    <% end %>
  </div>
</div>

<%# ── Filter tabs ──────────────────────────────── %>
<div class="flex gap-1 mb-6 bg-cream-dark rounded-xl p-1 w-fit">
  <% [["upcoming", "Próximas"], ["today", "Hoy"], ["past", "Anteriores"]].each do |value, label| %>
    <% active = (params[:filter] || "upcoming") == value %>
    <%= link_to label, dashboard_bookings_path(filter: value),
        class: "px-4 py-1.5 rounded-lg text-sm font-medium transition-colors #{active ? 'bg-white text-forest shadow-sm' : 'text-forest/50 hover:text-forest'}" %>
  <% end %>
</div>

<%# ── Bookings list ─────────────────────────────── %>
<% if @bookings.any? %>
  <div class="space-y-2">
    <% @bookings.each do |booking| %>
      <%= link_to dashboard_booking_path(booking),
          class: "group flex flex-col gap-3 rounded-2xl border border-cream-dark bg-white px-5 py-4 hover:border-brand/30 hover:shadow-sm transition-all sm:flex-row sm:items-center sm:gap-4" do %>

        <div class="flex min-w-0 items-start gap-4 sm:flex-1 sm:items-center">
          <%# Date block %>
          <div class="w-12 shrink-0 text-center">
            <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-forest/40">
              <%= I18n.l(booking.starts_at.to_date, format: "%b") %>
            </p>
            <p class="mt-0.5 text-2xl font-bold leading-none text-forest">
              <%= booking.starts_at.strftime("%d") %>
            </p>
          </div>

          <%# Divider %>
          <div class="hidden h-12 w-px shrink-0 bg-cream-dark sm:block"></div>

          <%# Time + service %>
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
              <span class="text-base font-bold text-forest">
                <%= booking.starts_at.strftime("%H:%M") %>
              </span>
              <span class="min-w-0 text-sm text-forest/60 sm:truncate">
                <%= booking.service&.name || "Servicio eliminado" %>
              </span>
            </div>
            <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1">
              <% if booking.customer %>
                <span class="flex items-center gap-1 text-xs text-forest/50">
                  <svg class="h-3 w-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                  </svg>
                  <span class="truncate"><%= booking.customer.name %></span>
                </span>
              <% end %>
              <% if booking.user %>
                <span class="text-xs text-forest/40">· <%= booking.user.name %></span>
              <% end %>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-end gap-3 sm:shrink-0">
          <%# Status badge %>
          <div class="shrink-0">
            <%= booking_status_badge(booking.status) %>
          </div>

          <%# Arrow %>
          <svg class="h-4 w-4 shrink-0 text-forest/20 transition-colors group-hover:text-brand/40" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
          </svg>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <%# Empty state %>
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <div class="w-14 h-14 rounded-2xl bg-cream-dark flex items-center justify-center mb-4">
      <svg class="w-7 h-7 text-forest/30" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
      </svg>
    </div>
    <p class="font-fraunces text-lg text-forest/60">No hay citas</p>
    <p class="text-sm text-forest/40 mt-1 mb-5">
      <% if (params[:filter] || "upcoming") == "today" %>
        No tienes citas programadas para hoy.
      <% elsif params[:filter] == "past" %>
        No hay citas anteriores registradas.
      <% else %>
        Aún no tienes citas próximas.
      <% end %>
    </p>
    <%= link_to "Crear primera cita", new_dashboard_booking_path,
        class: "inline-flex items-center gap-2 rounded-xl bg-brand px-4 py-2.5 text-sm font-semibold text-white hover:bg-brand-light transition-colors" %>
  </div>
<% end %>
