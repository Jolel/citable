<% content_for :title, "Editar cita" %>

<div class="max-w-xl">
  <div class="mb-6">
    <%= link_to dashboard_booking_path(@booking),
        class: "inline-flex items-center gap-1.5 text-sm text-forest/50 hover:text-forest transition-colors mb-4" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
      </svg>
      Ver cita
    <% end %>
    <h1 class="font-fraunces text-2xl font-light text-forest">Editar cita</h1>
    <p class="text-sm text-forest/50 mt-0.5">
      <%= @booking.service&.name %> ·
      <%= @booking.starts_at.strftime("%d/%m/%Y %H:%M") %>
    </p>
  </div>

  <div class="rounded-2xl border border-cream-dark bg-white p-6">
    <%= render "form", booking: @booking %>
  </div>
</div>
