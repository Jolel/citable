<% content_for :title, "Cita — #{@booking.customer&.name}" %>

<%# ── Back + actions header ─────────────────────── %>
<div class="flex items-center justify-between gap-4 mb-6">
  <%= link_to dashboard_bookings_path,
      class: "inline-flex items-center gap-1.5 text-sm text-forest/50 hover:text-forest transition-colors" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
    </svg>
    Citas
  <% end %>

  <div class="flex items-center gap-2">
    <%= link_to edit_dashboard_booking_path(@booking),
        class: "inline-flex items-center gap-1.5 rounded-lg border border-cream-dark px-3 py-1.5 text-sm font-medium text-forest/70 hover:border-forest/30 hover:text-forest transition-colors" do %>
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
      </svg>
      Editar
    <% end %>
  </div>
</div>

<%# ── Main card ───────────────────────────────────── %>
<div class="rounded-2xl border border-cream-dark bg-white overflow-hidden mb-4">

  <%# Status banner %>
  <div class="px-6 py-4 border-b border-cream-dark flex items-center justify-between gap-4">
    <div>
      <p class="text-[10px] font-semibold tracking-widest uppercase text-forest/40 mb-1">Estado</p>
      <%= booking_status_badge(@booking.status) %>
    </div>

    <%# Confirm / Cancel actions %>
    <div class="flex gap-2">
      <% if @booking.status == "pending" %>
        <%= button_to confirm_dashboard_booking_path(@booking), method: :patch,
            class: "inline-flex items-center gap-1.5 rounded-xl bg-forest px-4 py-2 text-sm font-semibold text-cream hover:bg-forest-mid transition-colors" do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
          Confirmar
        <% end %>
      <% end %>
      <% unless ["cancelled", "completed", "no_show"].include?(@booking.status) %>
        <%= button_to cancel_dashboard_booking_path(@booking), method: :patch,
            data: { turbo_confirm: "¿Cancelar esta cita?" },
            class: "inline-flex items-center gap-1.5 rounded-xl border border-red-200 bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-100 transition-colors" do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
          Cancelar
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Details grid %>
  <dl class="divide-y divide-cream-dark">
    <div class="px-6 py-4 grid grid-cols-3 gap-4">
      <dt class="text-xs font-semibold text-forest/40 uppercase tracking-wider col-span-1 pt-0.5">Servicio</dt>
      <dd class="col-span-2">
        <p class="text-sm font-semibold text-forest"><%= @booking.service&.name || "—" %></p>
        <% if @booking.service %>
          <p class="text-xs text-forest/50 mt-0.5">
            <%= @booking.service.duration_label %> ·
            $<%= number_with_delimiter(@booking.service.price_cents / 100) %> MXN
          </p>
        <% end %>
      </dd>
    </div>

    <div class="px-6 py-4 grid grid-cols-3 gap-4">
      <dt class="text-xs font-semibold text-forest/40 uppercase tracking-wider col-span-1 pt-0.5">Fecha y hora</dt>
      <dd class="col-span-2">
        <p class="text-sm font-semibold text-forest">
          <%= @booking.starts_at.strftime("%A %d de %B, %Y").capitalize %>
        </p>
        <p class="text-xs text-forest/50 mt-0.5">
          <%= @booking.starts_at.strftime("%H:%M") %>
          <% if @booking.ends_at %>
            – <%= @booking.ends_at.strftime("%H:%M") %>
          <% end %>
        </p>
      </dd>
    </div>

    <% if @booking.customer %>
      <div class="px-6 py-4 grid grid-cols-3 gap-4">
        <dt class="text-xs font-semibold text-forest/40 uppercase tracking-wider col-span-1 pt-0.5">Cliente</dt>
        <dd class="col-span-2">
          <p class="text-sm font-semibold text-forest">
            <%= link_to @booking.customer.name, dashboard_customer_path(@booking.customer),
                class: "hover:text-brand transition-colors" %>
          </p>
          <% if @booking.customer.phone.present? %>
            <a href="<%= whatsapp_link(@booking.customer.phone) %>" target="_blank" rel="noopener"
               class="inline-flex items-center gap-1.5 text-xs text-wa-dark hover:text-wa mt-1 transition-colors">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
              </svg>
              <%= @booking.customer.phone %>
            </a>
          <% end %>
        </dd>
      </div>
    <% end %>

    <% if @booking.user %>
      <div class="px-6 py-4 grid grid-cols-3 gap-4">
        <dt class="text-xs font-semibold text-forest/40 uppercase tracking-wider col-span-1 pt-0.5">Colaborador</dt>
        <dd class="col-span-2">
          <p class="text-sm text-forest"><%= @booking.user.name %></p>
        </dd>
      </div>
    <% end %>

    <% if @booking.address.present? %>
      <div class="px-6 py-4 grid grid-cols-3 gap-4">
        <dt class="text-xs font-semibold text-forest/40 uppercase tracking-wider col-span-1 pt-0.5">Dirección</dt>
        <dd class="col-span-2">
          <p class="text-sm text-forest"><%= @booking.address %></p>
        </dd>
      </div>
    <% end %>

    <% if @booking.service&.deposit_required? %>
      <div class="px-6 py-4 grid grid-cols-3 gap-4">
        <dt class="text-xs font-semibold text-forest/40 uppercase tracking-wider col-span-1 pt-0.5">Depósito</dt>
        <dd class="col-span-2">
          <% case @booking.deposit_state %>
          <% when "deposit_pending" %>
            <span class="badge-pending">Pendiente de pago</span>
          <% when "deposit_paid" %>
            <span class="badge-confirmed">Pagado</span>
          <% when "deposit_refunded" %>
            <span class="badge-cancelled">Reembolsado</span>
          <% end %>
        </dd>
      </div>
    <% end %>
  </dl>
</div>

<%# Timestamps %>
<p class="text-xs text-center text-forest/30">
  Creada <%= time_ago_in_words(@booking.created_at) %> atrás
  <% if @booking.confirmed_at %>
    · Confirmada <%= time_ago_in_words(@booking.confirmed_at) %> atrás
  <% end %>
</p>
