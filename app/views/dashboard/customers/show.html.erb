<% content_for :title, @customer.name %>

<%# ── Back + actions ───────────────────────────── %>
<div class="flex items-center justify-between gap-4 mb-6">
  <%= link_to dashboard_customers_path,
      class: "inline-flex items-center gap-1.5 text-sm text-forest/50 hover:text-forest transition-colors" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
    </svg>
    Clientes
  <% end %>

  <div class="flex items-center gap-2">
    <%= link_to edit_dashboard_customer_path(@customer),
        class: "inline-flex items-center gap-1.5 rounded-lg border border-cream-dark px-3 py-1.5 text-sm font-medium text-forest/70 hover:border-forest/30 hover:text-forest transition-colors" do %>
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
      </svg>
      Editar
    <% end %>
    <%= button_to dashboard_customer_path(@customer), method: :delete,
        data: { turbo_confirm: "¿Eliminar a #{@customer.name}? Esta acción no se puede deshacer." },
        class: "inline-flex items-center gap-1.5 rounded-lg border border-red-200 px-3 py-1.5 text-sm font-medium text-red-600 hover:bg-red-50 transition-colors" do %>
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
      </svg>
      Eliminar
    <% end %>
  </div>
</div>

<%# ── Profile card ────────────────────────────────── %>
<div class="rounded-2xl border border-cream-dark bg-white p-6 mb-4">
  <div class="flex items-start gap-4">
    <div class="w-14 h-14 rounded-2xl bg-brand-muted flex items-center justify-center shrink-0">
      <span class="text-xl font-bold text-brand"><%= @customer.name.to_s.first.upcase %></span>
    </div>
    <div class="min-w-0 flex-1">
      <h1 class="font-fraunces text-2xl font-light text-forest"><%= @customer.name %></h1>
      <% if @customer.phone.present? %>
        <a href="<%= whatsapp_link(@customer.phone) %>" target="_blank" rel="noopener"
           class="inline-flex items-center gap-1.5 text-sm text-wa-dark hover:text-wa mt-1 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
          <%= @customer.phone %>
        </a>
      <% end %>

      <%# Tags %>
      <% if @customer.tags.present? %>
        <div class="flex items-center gap-1.5 flex-wrap mt-3">
          <% @customer.tags.each do |tag| %>
            <%= link_to tag, dashboard_customers_path(tag: tag),
                class: "inline-flex rounded-full bg-cream-dark px-3 py-1 text-xs font-semibold text-forest/60 hover:bg-brand-muted hover:text-brand transition-colors" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Notes %>
  <% if @customer.notes.present? %>
    <div class="mt-5 pt-5 border-t border-cream-dark">
      <p class="text-[10px] font-semibold tracking-widest uppercase text-forest/40 mb-2">Notas</p>
      <p class="text-sm text-forest/70 whitespace-pre-wrap"><%= @customer.notes %></p>
    </div>
  <% end %>

  <%# Quick actions %>
  <div class="mt-5 pt-5 border-t border-cream-dark flex gap-3">
    <%= link_to new_dashboard_booking_path(customer_id: @customer.id),
        class: "inline-flex items-center gap-2 rounded-xl bg-brand px-4 py-2.5 text-sm font-semibold text-white hover:bg-brand-light transition-colors" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      Nueva cita
    <% end %>
  </div>
</div>

<%# ── Booking history ────────────────────────────── %>
<div class="rounded-2xl border border-cream-dark bg-white overflow-hidden">
  <div class="px-5 py-4 border-b border-cream-dark">
    <h2 class="font-fraunces text-base font-light text-forest">
      Historial de citas
      <span class="ml-1.5 text-sm text-forest/40">(<%= @bookings.count %>)</span>
    </h2>
  </div>

  <% if @bookings.any? %>
    <% @bookings.each_with_index do |booking, i| %>
      <%= link_to dashboard_booking_path(booking),
          class: "flex items-center gap-4 px-5 py-3.5 hover:bg-cream transition-colors #{i > 0 ? 'border-t border-cream-dark' : ''}" do %>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-medium text-forest truncate"><%= booking.service&.name %></p>
          <p class="text-xs text-forest/50 mt-0.5"><%= booking.starts_at.strftime("%d/%m/%Y %H:%M") %></p>
        </div>
        <%= booking_status_badge(booking.status) %>
      <% end %>
    <% end %>
  <% else %>
    <div class="px-5 py-8 text-center">
      <p class="text-sm text-forest/40">Sin citas registradas todavía</p>
    </div>
  <% end %>
</div>
