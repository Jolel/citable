<% content_for :title, "Reserva tu cita — #{@account.name}" %>

<div data-controller="booking-flow">

  <%# ── Step indicator ─────────────────────────── %>
  <div class="flex items-center gap-2 mb-8">
    <% steps = [["Servicio", "1"], ["Fecha y hora", "2"], ["Tus datos", "3"]] %>
    <% steps.each_with_index do |(label, num), i| %>
      <div class="flex items-center gap-2 flex-1" data-booking-flow-target="stepIndicator" data-step="<%= i + 1 %>">
        <div class="flex items-center gap-1.5">
          <span class="w-6 h-6 rounded-full flex items-center justify-center text-[11px] font-bold shrink-0 step-circle-<%= i + 1 %>
            <%= i == 0 ? 'bg-forest text-cream' : 'bg-cream-dark text-forest/40' %>">
            <%= num %>
          </span>
          <span class="text-xs font-medium hidden sm:block <%= i == 0 ? 'text-forest' : 'text-forest/40' %>">
            <%= label %>
          </span>
        </div>
        <% if i < steps.size - 1 %>
          <div class="h-px flex-1 bg-cream-dark"></div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%= form_with url: public_booking_path, method: :post, class: "space-y-6", data: { booking_flow_target: "form" } do |f| %>

    <%# ────── STEP 1: Service selection ────────── %>
    <div data-booking-flow-target="step" data-step-index="1">
      <h2 class="font-fraunces text-xl font-light text-forest mb-1">¿Qué servicio necesitas?</h2>
      <p class="text-sm text-forest/50 mb-5">Selecciona el servicio que deseas reservar</p>

      <% if @services.any? %>
        <div class="space-y-3" id="service-cards">
          <% @services.each do |service| %>
            <label class="group relative flex items-start gap-4 rounded-2xl border border-cream-dark bg-white p-4 cursor-pointer hover:border-brand/40 hover:shadow-sm transition-all has-[:checked]:border-brand has-[:checked]:bg-brand-muted has-[:checked]:shadow-sm">
              <input type="radio" name="booking[service_id]" value="<%= service.id %>"
                     data-action="change->booking-flow#serviceSelected"
                     class="sr-only">

              <%# Service icon circle %>
              <div class="w-10 h-10 rounded-xl bg-cream-dark group-has-[:checked]:bg-brand/10 flex items-center justify-center shrink-0 transition-colors">
                <svg class="w-5 h-5 text-forest/40 group-has-[:checked]:text-brand transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
                </svg>
              </div>

              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-forest"><%= service.name %></p>
                <p class="text-xs text-forest/50 mt-0.5"><%= service.duration_label %></p>
              </div>

              <div class="text-right shrink-0">
                <p class="text-base font-bold text-forest">
                  $<%= number_with_delimiter(service.price_cents / 100) %>
                </p>
                <% if service.deposit_required? %>
                  <p class="text-[10px] text-brand font-semibold mt-0.5">
                    Depósito en efectivo $<%= number_with_delimiter(service.deposit_amount_cents / 100) %>
                  </p>
                <% end %>
              </div>

              <%# Check indicator %>
              <div class="absolute top-4 right-4 w-5 h-5 rounded-full border-2 border-cream-dark group-has-[:checked]:border-brand group-has-[:checked]:bg-brand flex items-center justify-center transition-all">
                <svg class="w-3 h-3 text-white opacity-0 group-has-[:checked]:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
              </div>
            </label>
          <% end %>
        </div>

        <button type="button"
                data-action="click->booking-flow#nextStep"
                data-booking-flow-target="nextBtn1"
                disabled
                class="mt-6 w-full rounded-2xl bg-brand py-3.5 text-sm font-bold text-white shadow-sm hover:bg-brand-light transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
          Continuar
        </button>
      <% else %>
        <div class="rounded-2xl border border-cream-dark bg-white p-8 text-center">
          <p class="text-forest/60">Este negocio aún no tiene servicios disponibles.</p>
        </div>
      <% end %>
    </div>

    <%# ────── STEP 2: Date & time ───────────────── %>
    <div data-booking-flow-target="step" data-step-index="2" class="hidden">
      <button type="button" data-action="click->booking-flow#prevStep"
              class="inline-flex items-center gap-1 text-sm text-forest/50 hover:text-forest mb-5 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
        </svg>
        Cambiar servicio
      </button>

      <h2 class="font-fraunces text-xl font-light text-forest mb-1">¿Cuándo quieres tu cita?</h2>
      <p class="text-sm text-forest/50 mb-5">Elige la fecha y hora que más te convenga</p>

      <div class="rounded-2xl border border-cream-dark bg-white p-5">
        <label class="block text-xs font-semibold uppercase tracking-wider text-forest/40 mb-3">
          Fecha y hora
        </label>
        <%= f.datetime_local_field :starts_at,
            min: Time.current.strftime("%Y-%m-%dT%H:%M"),
            class: "block w-full rounded-xl border border-cream-dark bg-cream px-3.5 py-3 text-sm text-forest focus:border-brand focus:ring-2 focus:ring-brand/10 focus:outline-none" %>

        <p class="text-xs text-forest/40 mt-3 leading-relaxed">
          Selecciona una fecha disponible. Recibirás una confirmación por WhatsApp.
        </p>
      </div>

      <%# Optional address if service might be at home %>
      <div class="mt-4 rounded-2xl border border-cream-dark bg-white p-5">
        <label class="block text-xs font-semibold uppercase tracking-wider text-forest/40 mb-3">
          Dirección (solo si es a domicilio)
        </label>
        <%= f.text_field :address,
            placeholder: "Deja en blanco si vas al local",
            class: "block w-full rounded-xl border border-cream-dark bg-cream px-3.5 py-3 text-sm text-forest placeholder:text-forest/30 focus:border-brand focus:ring-2 focus:ring-brand/10 focus:outline-none" %>
      </div>

      <button type="button"
              data-action="click->booking-flow#nextStep"
              class="mt-6 w-full rounded-2xl bg-brand py-3.5 text-sm font-bold text-white shadow-sm hover:bg-brand-light transition-colors">
        Continuar
      </button>
    </div>

    <%# ────── STEP 3: Customer details ──────────── %>
    <div data-booking-flow-target="step" data-step-index="3" class="hidden">
      <button type="button" data-action="click->booking-flow#prevStep"
              class="inline-flex items-center gap-1 text-sm text-forest/50 hover:text-forest mb-5 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
        </svg>
        Cambiar fecha
      </button>

      <h2 class="font-fraunces text-xl font-light text-forest mb-1">Tus datos</h2>
      <p class="text-sm text-forest/50 mb-5">Para enviarte la confirmación por WhatsApp</p>

      <%# Booking summary %>
      <div class="rounded-2xl border border-brand/20 bg-brand-muted p-4 mb-5" data-booking-flow-target="summary">
        <p class="text-xs font-semibold text-brand uppercase tracking-wider mb-2">Tu reserva</p>
        <p class="text-sm font-semibold text-forest" data-booking-flow-target="summaryService">—</p>
        <p class="text-xs text-forest/60 mt-0.5" data-booking-flow-target="summaryTime">—</p>
      </div>

      <div class="space-y-4">
        <div>
          <label class="block text-xs font-semibold uppercase tracking-wider text-forest/50 mb-1.5">
            Tu nombre completo
          </label>
          <input type="text" name="customer_name" required
                 placeholder="Ej. Rosa Martínez"
                 class="block w-full rounded-xl border border-cream-dark bg-white px-3.5 py-3 text-sm text-forest placeholder:text-forest/30 focus:border-brand focus:ring-2 focus:ring-brand/10 focus:outline-none">
        </div>

        <div>
          <label class="block text-xs font-semibold uppercase tracking-wider text-forest/50 mb-1.5">
            Tu número de WhatsApp
          </label>
          <input type="tel" name="customer_phone" required
                 placeholder="+52 55 1234 5678"
                 class="block w-full rounded-xl border border-cream-dark bg-white px-3.5 py-3 text-sm text-forest placeholder:text-forest/30 focus:border-brand focus:ring-2 focus:ring-brand/10 focus:outline-none">
          <p class="text-xs text-forest/40 mt-1.5 flex items-center gap-1">
            <svg class="w-3.5 h-3.5 text-wa shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
            Recibirás confirmación y recordatorios por WhatsApp
          </p>
        </div>
      </div>

      <button type="submit"
              class="mt-6 w-full rounded-2xl bg-brand py-3.5 text-sm font-bold text-white shadow-sm hover:bg-brand-light transition-colors active:scale-[0.98]">
        Confirmar mi cita
      </button>

      <p class="mt-4 text-xs text-center text-forest/30">
        Al reservar aceptas que <%= @account.name %> te contacte por WhatsApp para recordatorios.
      </p>
    </div>

  <% end %>
</div>
