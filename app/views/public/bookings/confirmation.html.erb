<% content_for :title, "¡Cita confirmada! — #{@account.name}" %>

<div class="py-8 text-center">

  <%# Animated checkmark %>
  <div class="flex justify-center mb-6">
    <div class="relative w-20 h-20">
      <div class="w-20 h-20 rounded-full bg-emerald-50 border-2 border-emerald-200 flex items-center justify-center">
        <svg class="w-10 h-10 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
        </svg>
      </div>
    </div>
  </div>

  <h1 class="font-fraunces text-3xl font-light text-forest mb-2">¡Tu cita está agendada!</h1>
  <p class="text-sm text-forest/50 mb-8">
    Recibirás una confirmación por WhatsApp en breve.
  </p>

  <%# Booking details card %>
  <div class="rounded-2xl border border-cream-dark bg-white p-6 text-left mb-6">
    <dl class="space-y-4">
      <div>
        <dt class="text-[10px] font-semibold uppercase tracking-widest text-forest/40 mb-0.5">Negocio</dt>
        <dd class="text-sm font-semibold text-forest"><%= @account.name %></dd>
      </div>

      <% if @booking.service %>
        <div>
          <dt class="text-[10px] font-semibold uppercase tracking-widest text-forest/40 mb-0.5">Servicio</dt>
          <dd class="text-sm font-semibold text-forest"><%= @booking.service.name %></dd>
          <dd class="text-xs text-forest/50 mt-0.5">
            <%= @booking.service.duration_label %> ·
            $<%= number_with_delimiter(@booking.service.price_cents / 100) %> MXN
          </dd>
        </div>
      <% end %>

      <div>
        <dt class="text-[10px] font-semibold uppercase tracking-widest text-forest/40 mb-0.5">Fecha y hora</dt>
        <dd class="text-sm font-semibold text-forest">
          <%= @booking.starts_at.strftime("%A %d de %B, %Y").capitalize %>
        </dd>
        <dd class="text-xs text-forest/50 mt-0.5">
          <%= @booking.starts_at.strftime("%H:%M") %>
          <% if @booking.ends_at %>
            – <%= @booking.ends_at.strftime("%H:%M") %>
          <% end %>
        </dd>
      </div>

      <% if @booking.address.present? %>
        <div>
          <dt class="text-[10px] font-semibold uppercase tracking-widest text-forest/40 mb-0.5">Dirección</dt>
          <dd class="text-sm text-forest"><%= @booking.address %></dd>
        </div>
      <% end %>
    </dl>
  </div>

  <%# WhatsApp reminder info %>
  <div class="flex items-start gap-3 rounded-2xl bg-[#f0fdf4] border border-emerald-200 px-5 py-4 text-left mb-8">
    <svg class="w-5 h-5 text-wa shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
    </svg>
    <div>
      <p class="text-sm font-semibold text-forest">Recordatorios automáticos</p>
      <p class="text-xs text-forest/60 mt-0.5">
        Te enviaremos un recordatorio por WhatsApp 24 horas y 2 horas antes de tu cita.
        Responde <strong>1</strong> para confirmar o <strong>2</strong> para cancelar.
      </p>
    </div>
  </div>

  <%# Back to booking %>
  <%= link_to "Agendar otra cita", public_booking_path,
      class: "inline-flex items-center gap-2 rounded-2xl border border-cream-dark bg-white px-6 py-3 text-sm font-semibold text-forest hover:border-forest/30 transition-colors" %>
</div>
